<h2>All Blog Posts</h2>

<!-- Search -->
<form method="GET" action="/" style="margin-bottom:20px;">
  <input type="text" name="search" placeholder="Search by title or category or author" value="<%= typeof search !== 'undefined' ? search : '' %>">
  <button type="submit">Search</button>
</form>

<% if (!posts || posts.length === 0) { %>
  <p>No posts found.</p>
<% } %>

<% posts.forEach(function(post){ %>
  <article class="post">
    <h3><a href="/post/<%= post._id %>"><%= post.title %></a></h3>
    <p><small>by <%= post.author && post.author.username ? post.author.username : 'Unknown' %></small></p>

    <% 
      const content = (post.content || '');
      const lines = content.split(/\r?\n/);
      const showAll = lines.length <= 5;
    %>

    <% if (showAll) { %>
      <p>
        <% lines.forEach(function(line, i){ %>
          <%= line %><% if (i < lines.length - 1) { %><br><% } %>
        <% }) %>
      </p>
    <% } else { %>
      <p>
        <% for (let i = 0; i < 5; i++) { %>
          <%= lines[i] %><br>
        <% } %>
      </p>
      <a href="/post/<%= post._id %>">Show more</a>
    <% } %>

    <% if (user && (user.role === 'admin' || (post.author && String(post.author._id) === String(user._id)))) { %>
      <div style="margin-top:8px;">
        <a href="/edit/<%= post._id %>" class="btn-edit">Edit</a>
        <form method="POST" action="/delete/<%= post._id %>" 
              style="display:inline;margin-left:8px;" 
              onsubmit="return confirm('Are you sure you want to delete this post?');">
          <button type="submit" class="btn-delete">Delete</button>
        </form>
      </div>
    <% } %>
  </article>
  <hr>
<% }) %>
