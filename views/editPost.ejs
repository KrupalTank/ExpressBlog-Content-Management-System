
<h2>Edit Post</h2>
<form method="POST" action="/edit/<%= post._id %>">
  <label>Title:</label>
  <input type="text" name="title" value="<%= post.title %>" required><br>

  <label>Category:</label>
  <input type="text" name="category" value="<%= post.category %>" required><br>

  <label>Content:</label><br>
  <textarea name="content" rows="6" col
  s="50" required><%= post.content %></textarea><br>

  <button type="submit">Update Post</button>
</form>
